Cell[BoxData[
 RowBox[{
  RowBox[{"ExpET", "[", 
   RowBox[{"s_", ",", "I_", ",", "d_", ",", "T_", ",", "\[Sigma]_"}], "]"}], ":=", 
  RowBox[{
   RowBox[{
    FractionBox[
     RowBox[{"Exp", "[", 
      RowBox[{"I", "*", "T"}], "]"}], 
     RowBox[{"1", "-", "s"}]], "*", 
    RowBox[{"Fe", "[", 
     RowBox[{
      RowBox[{"\[Omega]def", "[", 
       RowBox[{"s", ",", "I", ",", "d", ",", "T"}], "]"}], ",", "\[Sigma]"}], 
     "]"}]}], "-", 
   RowBox[{
    FractionBox[
     RowBox[{"s", "*", 
      RowBox[{"Exp", "[", 
       RowBox[{"d", "*", "T"}], "]"}]}], 
     RowBox[{"1", "-", "s"}]], "*", 
    RowBox[{"Fec", "[", 
     RowBox[{
      RowBox[{"\[Omega]def", "[", 
       RowBox[{"s", ",", "I", ",", "d", ",", "T"}], "]"}], ",", "\[Sigma]"}], 
     "]"}]}]}]}]], "Input",
 CellChangeTimes->{
  3.978077801948126*^9, {3.9780778323763847`*^9, 3.978077978646576*^9}, {
   3.9780781225811176`*^9, 3.9780781664764214`*^9}},
 CellLabel->"In[73]:=",ExpressionUUID->"15e2e641-60fc-e941-b521-f410df095239"],

Cell[BoxData[
 RowBox[{
  RowBox[{"e", "[", 
   RowBox[{"s_", ",", "I_", ",", "d_", ",", "T_", ",", "\[Sigma]_"}], "]"}], ":=", 
  FractionBox[
   RowBox[{"Log", "[", 
    RowBox[{"ExpET", "[", 
     RowBox[{"s", ",", "I", ",", "d", ",", "T", ",", "\[Sigma]"}], "]"}], 
    "]"}], "T"]}]], "Input",
 CellChangeTimes->{{3.9780781739663944`*^9, 3.978078182712839*^9}, {
  3.978078222186451*^9, 3.978078255387541*^9}},
