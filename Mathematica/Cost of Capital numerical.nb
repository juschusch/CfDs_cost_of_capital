Cell[BoxData[
 RowBox[{
  RowBox[{"\[Omega]def", "[", 
   RowBox[{"s_", ",", "I_", ",", "d_", ",", "T_"}], "]"}], ":=", 
  RowBox[{"s", "*", 
   RowBox[{"Exp", "[", 
    RowBox[{
     RowBox[{"(", 
      RowBox[{"d", "-", "I"}], ")"}], "*", "T"}], "]"}]}]}]], "Input",
 CellChangeTimes->{{3.978077615327423*^9, 3.978077745848116*^9}},
 CellLabel->"In[70]:=",ExpressionUUID->"b9acba25-6bf5-bf4e-a2d4-817dd33ab1c5"],

Cell[BoxData[
 RowBox[{
  RowBox[{"Fe", "[", 
   RowBox[{"\[Omega]_", ",", "\[Sigma]_"}], "]"}], ":=", 
  RowBox[{
   FractionBox["1", "2"], 
   RowBox[{"(", 
    RowBox[{"1", "+", 
     RowBox[{"Erf", "[", 
      FractionBox[
       RowBox[{
        RowBox[{"-", 
         RowBox[{"Log", "[", "\[Omega]", "]"}]}], "+", 
        FractionBox[
         SuperscriptBox["\[Sigma]", "2"], "2"]}], 
       RowBox[{"\[Sigma]", "*", 
        RowBox[{"Sqrt", "[", "2", "]"}]}]], "]"}]}], ")"}]}]}]], "Input",
 CellChangeTimes->{{3.978077516516342*^9, 3.978077525895893*^9}, 
   3.9780775788533688`*^9},
