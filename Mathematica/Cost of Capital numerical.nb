  RowBox[{"OneMinusSExpET", "[", 
   RowBox[{"s_", ",", "I_", ",", "d_", ",", "T_", ",", "\[Sigma]_"}], "]"}], ":=", 
  RowBox[{
   RowBox[{
    RowBox[{"Exp", "[", 
     RowBox[{"I", "*", "T"}], "]"}], "*", 
    RowBox[{"Fe", "[", 
     RowBox[{
      RowBox[{"\[Omega]def", "[", 
       RowBox[{"s", ",", "I", ",", "d", ",", "T"}], "]"}], ",", "\[Sigma]"}], 
     "]"}]}], "-", 
   RowBox[{"s", "*", 
    RowBox[{"Exp", "[", 
     RowBox[{"d", "*", "T"}], "]"}], "*", 
    RowBox[{"Fec", "[", 
     RowBox[{
      RowBox[{"\[Omega]def", "[", 
       RowBox[{"s", ",", "I", ",", "d", ",", "T"}], "]"}], ",", "\[Sigma]"}], 
     "]"}]}]}]}]], "Input",
