Cell[BoxData[
 RowBox[{
  RowBox[{"rhs2", "[", 
   RowBox[{"s_", ",", "I_", ",", "d_", ",", "T_", ",", "\[Sigma]_"}], "]"}], ":=", 
  RowBox[{
   RowBox[{"Exp", "[", 
    RowBox[{"I", "*", "T"}], "]"}], "*", 
   FractionBox["1", "2"], 
   RowBox[{"(", 
    RowBox[{"1", "-", 
     RowBox[{"Erf", "[", 
      FractionBox[
       RowBox[{
        RowBox[{
         RowBox[{"(", 
          RowBox[{"I", "-", "d"}], ")"}], "*", "T"}], "-", 
        RowBox[{"Log", "[", "s", "]"}], "+", 
        FractionBox[
         SuperscriptBox["\[Sigma]", "2"], "2"]}], 
       RowBox[{"\[Sigma]", "*", 
        RowBox[{"Sqrt", "[", "2", "]"}]}]], "]"}]}], ")"}]}]}]], "Input",
 CellChangeTimes->{{3.977488488006489*^9, 3.9774884984772778`*^9}, {
