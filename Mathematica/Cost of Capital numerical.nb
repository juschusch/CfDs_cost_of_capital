Cell[BoxData[
 RowBox[{
  RowBox[{"Fec", "[", 
   RowBox[{"\[Omega]_", ",", "\[Sigma]_"}], "]"}], ":=", 
  RowBox[{
   FractionBox["1", "2"], 
   RowBox[{"(", 
    RowBox[{"1", "+", 
     RowBox[{"Erf", "[", 
      FractionBox[
       RowBox[{
        RowBox[{"-", 
         RowBox[{"Log", "[", "\[Omega]", "]"}]}], "-", 
        FractionBox[
         SuperscriptBox["\[Sigma]", "2"], "2"]}], 
