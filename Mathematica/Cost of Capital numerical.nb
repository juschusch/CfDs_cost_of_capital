Cell[BoxData[
 RowBox[{
  RowBox[{"F", "[", 
   RowBox[{"\[Omega]_", ",", "\[Sigma]_"}], "]"}], ":=", 
  RowBox[{
   FractionBox["1", "2"], 
   RowBox[{"(", 
    RowBox[{"1", "-", 
     RowBox[{"Erf", "[", 
      FractionBox[
       RowBox[{
        RowBox[{"Log", "[", "\[Omega]", "]"}], "+", 
        FractionBox[
         SuperscriptBox["\[Sigma]", "2"], "2"]}], 
       RowBox[{"\[Sigma]", "*", 
        RowBox[{"Sqrt", "[", "2", "]"}]}]], "]"}]}], ")"}]}]}]], "Input",
 CellChangeTimes->{{3.9774872406877594`*^9, 3.9774872744872303`*^9}, {
