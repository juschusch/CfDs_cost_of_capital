Cell[BoxData[
 RowBox[{
  RowBox[{"rd", "[", 
   RowBox[{"s_", ",", "I_", ",", "f_", ",", "T_", ",", "\[Sigma]_"}], "]"}], ":=", 
  RowBox[{"d", "/.", " ", 
   RowBox[{"FindRoot", "[", 
    RowBox[{
     RowBox[{"0", "==", 
      RowBox[{
       RowBox[{"-", 
        RowBox[{"lhs", "[", 
         RowBox[{"s", ",", "f", ",", "T"}], "]"}]}], "+", 
       RowBox[{"rhs1", "[", 
        RowBox[{"s", ",", "I", ",", "d", ",", "T", ",", "\[Sigma]"}], "]"}], "+", 
       RowBox[{"rhs2", "[", 
        RowBox[{"s", ",", "I", ",", "d", ",", "T", ",", "\[Sigma]"}], 
        "]"}]}]}], ",", 
     RowBox[{"{", 
      RowBox[{"d", ",", "0.015", ",", "0.", ",", "0.999"}], "}"}], ",", 
     RowBox[{"AccuracyGoal", "->", "8"}], ",", 
     RowBox[{"PrecisionGoal", "->", "8"}], ",", 
     RowBox[{"MaxIterations", "->", "1000"}]}], " ", 
    RowBox[{"(*", 
     RowBox[{"Guess", ",", "Min", ",", "Max"}], "*)"}], "]"}]}]}]], "Input",
 CellChangeTimes->{{3.978078975839924*^9, 3.978078975839924*^9}, {
  3.9780790174177895`*^9, 3.97807901770837*^9}},
 CellLabel->
  "In[109]:=",ExpressionUUID->"25af33e1-b0ce-6f4e-bdef-95e546dc349e"],

Cell[BoxData[
 RowBox[{
  RowBox[{"enum", "[", 
   RowBox[{"s_", ",", "I_", ",", "f_", ",", "T_", ",", "\[Sigma]_"}], "]"}], ":=", 
  FractionBox[
