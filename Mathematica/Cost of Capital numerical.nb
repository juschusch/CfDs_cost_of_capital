Cell[BoxData[
 RowBox[{
  RowBox[{"rhs1", "[", 
   RowBox[{"s_", ",", "I_", ",", "d_", ",", "T_", ",", "\[Sigma]_"}], "]"}], ":=", 
  RowBox[{"s", "*", 
   RowBox[{"Exp", "[", 
    RowBox[{"d", "*", "T"}], "]"}], "*", 
   FractionBox["1", "2"], 
   RowBox[{"(", 
    RowBox[{"1", "+", 
     RowBox[{"Erf", "[", 
      FractionBox[
       RowBox[{
        RowBox[{
         RowBox[{"(", 
          RowBox[{"I", "-", "d"}], ")"}], "*", "T"}], "-", 
        RowBox[{"Log", "[", "s", "]"}], "-", 
        FractionBox[
         SuperscriptBox["\[Sigma]", "2"], "2"]}], 
       RowBox[{"\[Sigma]", "*", 
        RowBox[{"Sqrt", "[", "2", "]"}]}]], "]"}]}], ")"}]}]}]], "Input",
 CellChangeTimes->{{3.9774883768464985`*^9, 3.977488479677536*^9}, {
   3.9774886013204823`*^9, 3.977488618078451*^9}, {3.977511271357052*^9, 
