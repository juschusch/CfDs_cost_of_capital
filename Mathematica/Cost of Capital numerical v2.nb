     RowBox[{
      RowBox[{"\[Omega]def", "[", 
       RowBox[{"s", ",", "I", ",", "d", ",", "T"}], "]"}], ",", "\[Sigma]"}], 
     "]"}]}], "+", 
   RowBox[{
