Cell[BoxData[
 RowBox[{
  RowBox[{"WACC", "[", 
   RowBox[{
    RowBox[{"I_", "?", "NumericQ"}], ",", 
    RowBox[{"fd_", "?", "NumericQ"}], ",", 
    RowBox[{"fe_", "?", "NumericQ"}], ",", 
    RowBox[{"T_", "?", "NumericQ"}], ",", 
    RowBox[{"\[Sigma]_", "?", "NumericQ"}]}], "]"}], ":=", 
  RowBox[{
   RowBox[{"Log", "[", 
    RowBox[{
     RowBox[{
      RowBox[{"sd", "[", 
       RowBox[{"I", ",", "fd", ",", "fe", ",", "T", ",", "\[Sigma]"}], "]"}], 
      "*", 
      RowBox[{"Exp", "[", 
       RowBox[{
        RowBox[{"rd", "[", 
         RowBox[{"I", ",", "fd", ",", "fe", ",", "T", ",", "\[Sigma]"}], 
         "]"}], "*", "T"}], "]"}]}], "+", 
     RowBox[{
      RowBox[{"(", 
       RowBox[{"1", "-", 
        RowBox[{"sd", "[", 
         RowBox[{"I", ",", "fd", ",", "fe", ",", "T", ",", "\[Sigma]"}], 
         "]"}]}], ")"}], "*", 
      RowBox[{"Exp", "[", 
       RowBox[{"fe", "*", "T"}], "]"}]}]}], "]"}], "/", "T"}]}]], "Input",
