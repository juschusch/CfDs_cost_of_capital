Cell[BoxData[
 RowBox[{
  RowBox[{"rhs2", "[", 
   RowBox[{"s_", ",", "I_", ",", "d_", ",", "T_", ",", "\[Sigma]_"}], "]"}], ":=", 
  RowBox[{
   RowBox[{
    FractionBox[
     RowBox[{"Exp", "[", 
      RowBox[{"I", "*", "T"}], "]"}], 
     RowBox[{"1", "-", "s"}]], "*", 
    RowBox[{"Fe", "[", 
     RowBox[{
      RowBox[{"\[Omega]def", "[", 
       RowBox[{"s", ",", "I", ",", "d", ",", "T"}], "]"}], ",", "\[Sigma]"}], 
     "]"}]}], "-", 
   RowBox[{
    FractionBox[
     RowBox[{"s", "*", 
      RowBox[{"Exp", "[", 
       RowBox[{"d", "*", "T"}], "]"}]}], 
     RowBox[{"1", "-", "s"}]], "*", 
    RowBox[{"Fec", "[", 
     RowBox[{
      RowBox[{"\[Omega]def", "[", 
       RowBox[{"s", ",", "I", ",", "d", ",", "T"}], "]"}], ",", "\[Sigma]"}], 
     "]"}]}]}]}]], "Input",
