Cell[BoxData[
 RowBox[{
  RowBox[{"sol", "[", 
   RowBox[{
    RowBox[{"I_", "?", "NumericQ"}], ",", 
    RowBox[{"fd_", "?", "NumericQ"}], ",", 
    RowBox[{"fe_", "?", "NumericQ"}], ",", 
    RowBox[{"T_", "?", "NumericQ"}], ",", 
    RowBox[{"\[Sigma]_", "?", "NumericQ"}]}], "]"}], ":=", 
  RowBox[{"FindRoot", "[", 
   RowBox[{
    RowBox[{"{", 
     RowBox[{
      RowBox[{
       RowBox[{"lhs", "[", 
        RowBox[{"s", ",", "fd", ",", "T"}], "]"}], "==", 
       RowBox[{"rhs1", "[", 
        RowBox[{"s", ",", "I", ",", "d", ",", "T", ",", "\[Sigma]"}], "]"}]}],
       ",", 
      RowBox[{
       RowBox[{"lhs", "[", 
        RowBox[{"s", ",", "fe", ",", "T"}], "]"}], "==", 
       RowBox[{"rhs2", "[", 
        RowBox[{"s", ",", "I", ",", "d", ",", "T", ",", "\[Sigma]"}], 
        "]"}]}]}], "}"}], ",", 
