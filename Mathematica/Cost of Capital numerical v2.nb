    RowBox[{"PrecisionGoal", "->", "8"}], ",", 
    RowBox[{"MaxIterations", "->", "1000"}]}], " ", 
   RowBox[{"(*", 
    RowBox[{"Guess", ",", "Min", ",", "Max"}], "*)"}], "]"}]}]], "Input",
