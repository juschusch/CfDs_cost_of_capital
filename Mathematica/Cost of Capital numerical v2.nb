  RowBox[{"rd", "[", 
   RowBox[{
    RowBox[{"I_", "?", "NumericQ"}], ",", 
    RowBox[{"fd_", "?", "NumericQ"}], ",", 
    RowBox[{"fe_", "?", "NumericQ"}], ",", 
    RowBox[{"T_", "?", "NumericQ"}], ",", 
    RowBox[{"\[Sigma]_", "?", "NumericQ"}]}], "]"}], ":=", 
  RowBox[{"d", "/.", " ", 
