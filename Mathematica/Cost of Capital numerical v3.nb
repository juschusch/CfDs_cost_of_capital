Notebook[{
Cell[BoxData[
 RowBox[{
  RowBox[{"\[Omega]def", "[", 
   RowBox[{"I_", ",", "d_", ",", "T_"}], "]"}], ":=", 
  RowBox[{"Exp", "[", 
   RowBox[{
    RowBox[{"(", 
     RowBox[{"d", "-", "I"}], ")"}], "*", "T"}], "]"}]}]], "Input",
 CellChangeTimes->{{3.978688947145767*^9, 3.9786889491789284`*^9}},
 CellLabel->"In[1]:=",ExpressionUUID->"d56b93e3-5cc2-2448-8682-f4c2bf9cc66a"],

Cell[BoxData[
 RowBox[{
  RowBox[{"F", "[", 
   RowBox[{"\[Omega]_", ",", "\[Sigma]_"}], "]"}], ":=", 
  RowBox[{
   FractionBox["1", "2"], 
   RowBox[{"(", 
    RowBox[{"1", "+", 
     RowBox[{"Erf", "[", 
      FractionBox[
       RowBox[{
        RowBox[{"-", 
         RowBox[{"Log", "[", "\[Omega]", "]"}]}], "-", 
        FractionBox[
         SuperscriptBox["\[Sigma]", "2"], "2"]}], 
       RowBox[{"\[Sigma]", "*", 
        RowBox[{"Sqrt", "[", "2", "]"}]}]], "]"}]}], ")"}]}]}]], "Input",
 CellChangeTimes->{{3.9774872406877594`*^9, 3.9774872744872303`*^9}, {
  3.9774873063672943`*^9, 3.9774873132682323`*^9}, {3.9774873508672733`*^9, 
