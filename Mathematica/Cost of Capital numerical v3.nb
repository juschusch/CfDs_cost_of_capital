Cell[BoxData[
 RowBox[{
  RowBox[{"lhs", "[", 
   RowBox[{"f_", ",", "T_"}], "]"}], ":=", 
  RowBox[{"Exp", "[", 
   RowBox[{"f", "*", "T"}], "]"}]}]], "Input",
 CellChangeTimes->{{3.9774886474272175`*^9, 3.97748867381719*^9}, {
  3.978689019304346*^9, 3.9786890214448414`*^9}},
