Cell[BoxData[
 RowBox[{
  RowBox[{"rdeq", "[", 
   RowBox[{
    RowBox[{"f_", "?", "NumericQ"}], ",", 
    RowBox[{"T_", "?", "NumericQ"}], ",", 
    RowBox[{"\[Sigma]_", "?", "NumericQ"}]}], "]"}], ":=", 
  RowBox[{"I", "/.", " ", 
   RowBox[{"FindRoot", "[", 
    RowBox[{
     RowBox[{"I", "==", 
      RowBox[{"rd", "[", 
       RowBox[{"I", ",", "f", ",", "T", ",", "\[Sigma]"}], "]"}]}], ",", 
     RowBox[{"{", 
      RowBox[{"I", ",", 
       RowBox[{"f", "+", "0.01"}], ",", "f", ",", "1"}], "}"}], ",", 
     RowBox[{"AccuracyGoal", "->", "8"}], ",", 
     RowBox[{"PrecisionGoal", "->", "8"}], ",", 
     RowBox[{"MaxIterations", "->", "1000"}]}], " ", 
    RowBox[{"(*", 
     RowBox[{"Guess", ",", "Min", ",", "Max"}], "*)"}], "]"}]}]}]], "Input",
 CellChangeTimes->{{3.9786912910645885`*^9, 3.978691397844059*^9}},
 CellLabel->"In[21]:=",ExpressionUUID->"2ecd1468-9168-9340-a975-dc07fec1a79c"],

