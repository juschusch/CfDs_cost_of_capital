Cell[BoxData[
 RowBox[{
  RowBox[{"rhs2", "[", 
   RowBox[{"I_", ",", "d_", ",", "T_", ",", "\[Sigma]_"}], "]"}], ":=", 
  RowBox[{
   RowBox[{"Exp", "[", 
    RowBox[{"I", "*", "T"}], "]"}], "*", 
   RowBox[{"Fc", "[", 
    RowBox[{
     RowBox[{"\[Omega]def", "[", 
      RowBox[{"I", ",", "d", ",", "T"}], "]"}], ",", "\[Sigma]"}], 
