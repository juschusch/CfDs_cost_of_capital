 CellLabel->"In[2]:=",ExpressionUUID->"0990cbbd-5a55-d241-9420-7244b889e500"],

Cell[BoxData[
 RowBox[{
  RowBox[{"Fc", "[", 
   RowBox[{"\[Omega]_", ",", "\[Sigma]_"}], "]"}], ":=", 
  RowBox[{
   FractionBox["1", "2"], 
   RowBox[{"(", 
    RowBox[{"1", "-", 
     RowBox[{"Erf", "[", 
      FractionBox[
       RowBox[{
        RowBox[{"-", 
         RowBox[{"Log", "[", "\[Omega]", "]"}]}], "+", 
        FractionBox[
         SuperscriptBox["\[Sigma]", "2"], "2"]}], 
       RowBox[{"\[Sigma]", "*", 
        RowBox[{"Sqrt", "[", "2", "]"}]}]], "]"}]}], ")"}]}]}]], "Input",
 CellChangeTimes->{{3.9774830584398823`*^9, 3.9774830589915943`*^9}, {
  3.97748834377804*^9, 3.9774883531918316`*^9}, {3.977511704465866*^9, 
  3.9775117047172775`*^9}, {3.9784989217467613`*^9, 3.9784989295333366`*^9}},
 CellLabel->"In[3]:=",ExpressionUUID->"94fc7ebb-2099-d346-9dce-891a4344c14b"],

Cell[BoxData[
 RowBox[{
  RowBox[{"rhs1", "[", 
   RowBox[{"I_", ",", "d_", ",", "T_", ",", "\[Sigma]_"}], "]"}], ":=", 
  RowBox[{
   RowBox[{"Exp", "[", 
    RowBox[{"d", "*", "T"}], "]"}], "*", 
   RowBox[{"F", "[", 
    RowBox[{
     RowBox[{"\[Omega]def", "[", 
      RowBox[{"I", ",", "d", ",", "T"}], "]"}], ",", "\[Sigma]"}], 
    "]"}]}]}]], "Input",
 CellChangeTimes->{{3.9774883768464985`*^9, 3.977488479677536*^9}, {
