Cell[BoxData[
 RowBox[{
  RowBox[{"e", "[", 
   RowBox[{"s_", ",", "I_", ",", "d_", ",", "T_", ",", "\[Sigma]_"}], "]"}], ":=", 
  FractionBox[
   RowBox[{"Log", "[", 
    RowBox[{"ExpET", "[", 
     RowBox[{"s", ",", "I", ",", "d", ",", "T", ",", "\[Sigma]"}], "]"}], 
    "]"}], "T"]}]], "Input",
 CellChangeTimes->{{3.9780781739663944`*^9, 3.978078182712839*^9}, {
  3.978078222186451*^9, 3.978078255387541*^9}},
 CellLabel->"In[74]:=",ExpressionUUID->"f9fbf7e6-28ae-614b-9d39-e75bdfbfeb7b"],

Cell[BoxData[
 RowBox[{
  RowBox[{"enum", "[", 
   RowBox[{
    RowBox[{"s_", "?", "NumericQ"}], ",", 
    RowBox[{"I_", "?", "NumericQ"}], ",", 
    RowBox[{"f_", "?", "NumericQ"}], ",", 
    RowBox[{"T_", "?", "NumericQ"}], ",", 
    RowBox[{"\[Sigma]_", "?", "NumericQ"}]}], "]"}], ":=", 
  RowBox[{"FractionBox", "[", 
   RowBox[{
    RowBox[{"Log", "[", 
     RowBox[{"ExpET", "[", 
      RowBox[{"s", ",", "I", ",", 
       RowBox[{"rd", "[", 
        RowBox[{"s", ",", "I", ",", "f", ",", "T", ",", "\[Sigma]"}], "]"}], ",",
        "T", ",", "\[Sigma]"}], "]"}], "]"}], ",", "T"}], "]"}]}]], "Input",
 CellChangeTimes->{{3.9780783897299576`*^9, 3.9780784708377495`*^9}, {
   3.978078522968569*^9, 3.9780785235184784`*^9}, {3.978171253410887*^9, 
   3.978171283321327*^9}, {3.9781714112999*^9, 3.9781714395044956`*^9}, 
   3.9781717809588985`*^9},
 CellLabel->
  "In[185]:=",ExpressionUUID->"70b373c2-0e07-0349-bd1d-d781cbbbdfd3"],

Cell[BoxData[
 RowBox[{
  RowBox[{"re", "[", 
   RowBox[{"I_", ",", "f_", ",", "T_", ",", "\[Sigma]_"}], "]"}], ":=", 
  RowBox[{"NMaximize", "[", 
   RowBox[{
    RowBox[{"{", 
     RowBox[{
      RowBox[{"enum", "[", 
       RowBox[{"s", ",", "I", ",", "f", ",", "T", ",", "\[Sigma]"}], "]"}], ",", 
      RowBox[{"0.001", "<=", "s", "<=", "0.999"}]}], "}"}], ",", "s", ",", 
    RowBox[{"AccuracyGoal", "->", "8"}], ",", 
    RowBox[{"PrecisionGoal", "->", "8"}], ",", 
    RowBox[{"MaxIterations", "->", "1000"}]}], "]"}]}]], "Input",
 CellChangeTimes->{
  3.9781693651405487`*^9, {3.9781712114395504`*^9, 3.978171225021349*^9}, 
   3.9781713292296333`*^9, {3.97817149276157*^9, 3.978171518305084*^9}, 
   3.978171804880848*^9},
 CellLabel->
  "In[186]:=",ExpressionUUID->"958aa920-d8c8-1846-8dc2-69f88a0d77cf"],

Cell[BoxData[
 RowBox[{
  RowBox[{"ExpWACCTnum", "[", 
   RowBox[{
    RowBox[{"s_", "?", "NumericQ"}], ",", 
    RowBox[{"I_", "?", "NumericQ"}], ",", 
    RowBox[{"f_", "?", "NumericQ"}], ",", 
    RowBox[{"T_", "?", "NumericQ"}], ",", 
    RowBox[{"\[Sigma]_", "?", "NumericQ"}]}], "]"}], ":=", 
  RowBox[{
   RowBox[{"s", "*", 
    RowBox[{"Exp", "[", 
     RowBox[{
      RowBox[{"rd", "[", 
       RowBox[{"s", ",", "I", ",", "f", ",", "T", ",", "\[Sigma]"}], "]"}], "*",
       "T"}], "]"}]}], "+", 
   RowBox[{
    RowBox[{"(", 
     RowBox[{"1", "-", "s"}], ")"}], "*", 
    RowBox[{"ExpETnum", "[", 
     RowBox[{"s", ",", "I", ",", "f", ",", "T", ",", "\[Sigma]"}], 
     "]"}]}]}]}]], "Input",
 CellChangeTimes->{{3.978430253114216*^9, 3.9784303291943398`*^9}, {
  3.9784307632061214`*^9, 3.9784307647661858`*^9}, {3.9784322589560146`*^9, 
