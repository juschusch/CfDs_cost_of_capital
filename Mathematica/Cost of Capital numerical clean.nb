 RowBox[{
  RowBox[{"Fec", "[", 
   RowBox[{"\[Omega]_", ",", "\[Sigma]_"}], "]"}], ":=", 
  RowBox[{
   FractionBox["1", "2"], 
   RowBox[{"(", 
    RowBox[{"1", "+", 
