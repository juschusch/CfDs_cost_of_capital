Cell[BoxData[
 RowBox[{
  RowBox[{"rd", "[", 
   RowBox[{
    RowBox[{"s_", "?", "NumericQ"}], ",", 
    RowBox[{"I_", "?", "NumericQ"}], ",", 
    RowBox[{"f_", "?", "NumericQ"}], ",", 
    RowBox[{"T_", "?", "NumericQ"}], ",", 
    RowBox[{"\[Sigma]_", "?", "NumericQ"}]}], "]"}], ":=", 
  RowBox[{"d", "/.", " ", 
   RowBox[{"FindRoot", "[", 
    RowBox[{
     RowBox[{"0", "==", 
      RowBox[{
       RowBox[{"-", 
        RowBox[{"lhs", "[", 
         RowBox[{"s", ",", "f", ",", "T"}], "]"}]}], "+", 
       RowBox[{"rhs1", "[", 
        RowBox[{"s", ",", "I", ",", "d", ",", "T", ",", "\[Sigma]"}], "]"}], "+", 
       RowBox[{"rhs2", "[", 
        RowBox[{"s", ",", "I", ",", "d", ",", "T", ",", "\[Sigma]"}], 
        "]"}]}]}], ",", 
     RowBox[{"{", 
      RowBox[{"d", ",", "0.015", ",", "0.", ",", "0.999"}], "}"}], ",", 
     RowBox[{"AccuracyGoal", "->", "8"}], ",", 
     RowBox[{"PrecisionGoal", "->", "8"}], ",", 
     RowBox[{"MaxIterations", "->", "1000"}]}], " ", 
    RowBox[{"(*", 
     RowBox[{"Guess", ",", "Min", ",", "Max"}], "*)"}], "]"}]}]}]], "Input",
