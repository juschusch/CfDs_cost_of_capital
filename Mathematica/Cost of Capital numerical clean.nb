Cell[BoxData[
 RowBox[{
  RowBox[{"ExpET", "[", 
   RowBox[{"s_", ",", "I_", ",", "d_", ",", "T_", ",", "\[Sigma]_"}], "]"}], ":=", 
  RowBox[{
   RowBox[{
    FractionBox[
     RowBox[{"Exp", "[", 
      RowBox[{"I", "*", "T"}], "]"}], 
     RowBox[{"1", "-", "s"}]], "*", 
    RowBox[{"Fe", "[", 
     RowBox[{
      RowBox[{"\[Omega]def", "[", 
       RowBox[{"s", ",", "I", ",", "d", ",", "T"}], "]"}], ",", "\[Sigma]"}], 
     "]"}]}], "-", 
   RowBox[{
    FractionBox[
     RowBox[{"s", "*", 
      RowBox[{"Exp", "[", 
       RowBox[{"d", "*", "T"}], "]"}]}], 
     RowBox[{"1", "-", "s"}]], "*", 
    RowBox[{"Fec", "[", 
     RowBox[{
      RowBox[{"\[Omega]def", "[", 
       RowBox[{"s", ",", "I", ",", "d", ",", "T"}], "]"}], ",", "\[Sigma]"}], 
     "]"}]}]}]}]], "Input",
 CellChangeTimes->{
  3.978077801948126*^9, {3.9780778323763847`*^9, 3.978077978646576*^9}, {
   3.9780781225811176`*^9, 3.9780781664764214`*^9}},
 CellLabel->"In[79]:=",ExpressionUUID->"4eb09573-c662-0a4f-9579-2d5b60d84a1a"],

Cell[BoxData[
 RowBox[{
  RowBox[{"ExpETnum", "[", 
   RowBox[{
    RowBox[{"s_", "?", "NumericQ"}], ",", 
    RowBox[{"I_", "?", "NumericQ"}], ",", 
    RowBox[{"f_", "?", "NumericQ"}], ",", 
    RowBox[{"T_", "?", "NumericQ"}], ",", 
    RowBox[{"\[Sigma]_", "?", "NumericQ"}]}], "]"}], ":=", 
  RowBox[{"ExpET", "[", 
   RowBox[{"s", ",", "I", ",", 
    RowBox[{"rd", "[", 
     RowBox[{"s", ",", "I", ",", "f", ",", "T", ",", "\[Sigma]"}], "]"}], ",",
     "T", ",", "\[Sigma]"}], "]"}]}]], "Input",
